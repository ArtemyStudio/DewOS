modules = ["bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build ISO"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash --login"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Build ISO"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/build-and-release.sh"

[workflows.workflow.metadata]
outputType = "console"
